generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  passwordHash String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Organization {
  id             BigInt   @id @default(autoincrement())
  name           String
  type           String
  industry       String?
  locationCity   String?
  locationRegion String?
  website        String?
  phone          String
  email          String?
  description    String?

  status         String   @default("pending")
  verified       Boolean  @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  people         Person[]
}

model Person {
  id                 BigInt        @id @default(autoincrement())
  fullName           String
  phone              String
  email              String?

  currentOrganizationId BigInt?
  currentOrganization Organization? @relation(fields: [currentOrganizationId], references: [id], onDelete: SetNull)
  
  jobTitle           String?
  skills             String[]
  experienceYears    Int?
  locationCity       String?
  locationRegion     String?
  employed           Boolean?
  verified           Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}